# =================================================================
# CONFIGURACIÓN DEL COLECTOR AUTÓNOMO WIN NETWATCH
# =================================================================

# 1. Configuración de Firebase (Conexión a la nube)
FIREBASE_PROJECT_ID=network-monitor-36186
FIREBASE_API_KEY=AIzaSyAptyWP56e5m8nxprmxNQpETfWwHOlvBkY

# Credenciales para autenticar en Firebase (debe ser un usuario activo en el sistema)
COLLECTOR_EMAIL=admin@mg.cl
COLLECTOR_PASSWORD=123456

# 2. Configuración de Escaneo de Red
# Subredes a escanear separadas por comas (formato CIDR /24)
SCAN_SUBNETS=172.30.100.0/24,172.30.101.0/24,172.30.102.0/24,172.30.110.0/24,172.30.112.0/24

# Intervalo entre escaneos completos (en segundos)
SCAN_INTERVAL_SECONDS=120

# Hilos concurrentes de escaneo
SCAN_CONCURRENCY=50

# 3. Umbrales y Tiempos de Espera (Timeouts en milisegundos)
PING_TIMEOUT_MS=3000
PING_ATTEMPTS=2
RDP_TIMEOUT_MS=700
SLOW_THRESHOLD_MS=250

# Confianza mínima para registrar un equipo nuevo en la base de datos (0-10)
# (Evita falsos positivos por ruidos en la red)
NEW_DEVICE_MIN_CONFIDENCE=2

# Puertos a verificar para detectar presencia de Windows y otros servicios
WINDOWS_PROBE_PORTS=3389,445,135,139,5985,5986
